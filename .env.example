# Copy this file to `.env` and fill in the key for the stack you choose.
#
#   cp .env.example .env
#
# NEVER commit your real .env file. It is already in .gitignore.

# ---------------------------------------------------------------------------
# Evals are provider-agnostic — pick whichever you already have set up.
#
#   openai  -> OpenAI chat        (needs OPENAI_API_KEY)
#   claude  -> Claude messages    (needs ANTHROPIC_API_KEY)
#
# (Unlike the RAG repo, evals never need embeddings, so the claude stack here
#  needs only your Anthropic key — no Voyage key.)
#
# Default is "openai".
# ---------------------------------------------------------------------------
PROVIDER=openai

# --- For PROVIDER=openai ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# --- For PROVIDER=claude ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
